# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI
ANTHROPIC_API_KEY=sk-ant-your-key
GEMINI_API_KEY=your-gemini-key

# Voice
ELEVENLABS_API_KEY=sk_your-elevenlabs-key

# Pinecone (vector store for RAG)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_HOST=your-index-name.svc.aped-xxxx.pinecone.io

# Project identity — used as Pinecone namespace. MUST be unique per deployment.
# Generate: node -e "console.log(require('crypto').randomUUID())"
# WARNING: Two projects sharing the same PROJECT_ID will contaminate each other's knowledge base.
PROJECT_ID=generate-a-uuid-here

# Internal
TASK_PROCESSOR_SECRET=generate-a-64-char-hex-string
PROCESS_TASK_URL=https://your-site.netlify.app/.netlify/functions/process-task
